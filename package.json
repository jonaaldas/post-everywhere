{
  "name": "post-everywhere",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "tsx watch src/server.ts & cd web && vite --port 5173 & wait",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "cd web && vite --port 5173",
    "build": "tsc -p tsconfig.json && npx vue-tsc -b web && npx vite build web --outDir ../public",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@hono/node-server": "^1.19.11",
    "@types/node": "^24.12.0",
    "@libsql/client": "^0.17.0",
    "ai": "^6.0.116",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "ioredis": "^5.10.0",
    "octokit": "^5.0.5",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@pinia/colada": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-table": "^8.21.3",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.7",
    "esbuild": "^0.27.4",
    "lucide-vue-next": "^0.577.0",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "vue-tsc": "^3.2.5"
  }
}
